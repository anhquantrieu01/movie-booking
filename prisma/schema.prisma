// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum MovieStatus {
  COMING_SOON
  NOW_SHOWING
  ENDED
}

enum PaymentMethod {
  VNPAY
  MOMO
  STRIPE
  CASH
}

enum AgeRating {
  G
  PG
  PG13
  R
  NC17
  P
  C13
  C16
  C18
}

enum SeatType {
  NORMAL
  VIP
  COUPLE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  role          Role      @default(USER)
  bookings      Booking[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reviews Review[]
  @@index([email])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ================= MOVIE =================
model Movie {
  id          String      @id @default(uuid())
  title       String
  slug        String      @unique
  description String?
  duration    Int
  posterUrl   String?
  posterId    String?
  trailerUrl  String
  releaseDate DateTime
  status      MovieStatus @default(COMING_SOON)
  showtimes   Showtime[]
  language    String?
  country     String?
  ageRating AgeRating?
  reviews Review[]
  avgRating   Float   @default(0)
  reviewCount Int     @default(0)
  @@index([title])
  @@index([releaseDate])
}

// ================= CINEMA =================
model Cinema {
  id      String @id @default(uuid())
  name    String
  address String
  
  rooms Room[]

  @@index([name])
}

// ================= ROOM =================
model Room {
  id       String @id @default(uuid())
  name     String
  cinemaId String

  cinema    Cinema     @relation(fields: [cinemaId], references: [id], onDelete: Cascade)
  seats     Seat[]
  showtimes Showtime[]
  seatZones SeatZone[]
  verticalAisles   Int[]    @default([])
  horizontalAisles String[] @default([])

  @@index([cinemaId])
}

// ================= SEAT =================
model Seat {
  id     String @id @default(uuid())
  row    String
  number Int

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
 
  bookingSeats BookingSeat[]
  type SeatType @default(NORMAL)

  @@unique([roomId, row, number])
  @@index([roomId])
}

model SeatZone {
  id String @id @default(uuid())

  color String?

  startX Int
  endX Int
  startY Int
  endY Int

  roomId String
  room   Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  @@index([roomId])
}

// ================= SHOWTIME =================
model Showtime {
  id        String   @id @default(uuid())
  movieId   String
  roomId    String
  startTime DateTime
  endTime DateTime
  price     Float

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  room  Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)

  bookings     Booking[]
  bookingSeats BookingSeat[]
  @@unique([roomId, startTime])
  @@index([movieId])
  @@index([roomId])
  @@index([startTime])
  @@index([movieId, startTime]) // 🔥 query phim theo ngày
}

// ================= BOOKING =================
model Booking {
  id         String        @id @default(uuid())
  userId     String
  showtimeId String
  status     BookingStatus @default(PENDING)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  showtime Showtime @relation(fields: [showtimeId], references: [id], onDelete: Cascade)

  bookingSeats BookingSeat[]
  payment      Payment?

  createdAt DateTime @default(now())
  expiresAt DateTime?
  @@index([userId])
  @@index([showtimeId])
  @@index([status])
  @@index([userId, createdAt]) // lịch sử booking user
}

// ================= BOOKING SEAT =================
model BookingSeat {
  id String @id @default(uuid())

  bookingId  String
  seatId     String
  showtimeId String

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  seat     Seat     @relation(fields: [seatId], references: [id], onDelete: Cascade)
  showtime Showtime @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
  // 🔥 cực quan trọng: 1 ghế chỉ được đặt 1 lần trong 1 suất chiếu

  @@unique([seatId, showtimeId])
  @@index([bookingId])
  @@index([seatId])
  @@index([showtimeId])
}

// ================= PAYMENT =================
model Payment {
  id        String        @id @default(uuid())
  bookingId String        @unique
  amount    Float
  status    PaymentStatus @default(PENDING)
  method PaymentMethod?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([status])
}

model Review {
  id      String @id @default(uuid())

  userId  String
  movieId String

  rating  Int     // 1 -> 5 sao
  comment String? // optional

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  // 🔥 mỗi user chỉ được review 1 lần / phim
  @@unique([userId, movieId])

  @@index([movieId])
  @@index([userId])
}
